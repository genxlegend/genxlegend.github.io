/* ══════════════════════════════════════════════
   THEME (synced with portfolio)
   ══════════════════════════════════════════════ */
const root        = document.documentElement;
const themeToggle = document.getElementById('themeToggle');
const THEME_KEY   = 'gxl_theme';

const applyTheme = t => { root.setAttribute('data-theme', t); localStorage.setItem(THEME_KEY, t); };
applyTheme(localStorage.getItem(THEME_KEY) || 'light');
themeToggle.addEventListener('click', () => {
  applyTheme(root.getAttribute('data-theme') === 'light' ? 'dark' : 'light');
});

/* Hamburger */
const hamburger  = document.getElementById('hamburger');
const mobileMenu = document.getElementById('mobileMenu');
hamburger.addEventListener('click', () => {
  hamburger.classList.toggle('open');
  mobileMenu.classList.toggle('open');
});
mobileMenu.querySelectorAll('.mob-link').forEach(l => l.addEventListener('click', () => {
  hamburger.classList.remove('open');
  mobileMenu.classList.remove('open');
}));

/* ══════════════════════════════════════════════
   CONSOLE ENGINE
   ══════════════════════════════════════════════ */
const termBody   = document.getElementById('termBody');
const termStatus = document.getElementById('termStatus');
const failFlash  = document.getElementById('failFlash');
const emojiStage = document.getElementById('emojiStage');
const roundTrack = document.getElementById('roundTrack');

/* ── Sequences ── */
const SEQUENCES = [
  {
    label: 'Round 1',
    lines: [
      { type: 'divider', text: '─────────────────── attempt #1 ────────────────────' },
      { type: 'cmd',     text: 'ping page.html --locate --timeout=5' },
      { type: 'err',     text: 'Request timeout... 3/3 packets lost (RIP)' },
      { type: 'cmd',     text: 'sudo find / -name "missing-page.html"' },
      { type: 'warn',    text: 'find: \'/sys\': Permission denied' },
      { type: 'err',     text: 'find: \'/root\': Permission denied (try harder)' },
      { type: 'cmd',     text: 'npm install fix-my-404 --save-dev' },
      { type: 'info',    text: 'npm: sill idealTree buildDeps...' },
      { type: 'err',     text: 'npm ERR! 404 Not Found: \'fix-my-404\' is not a package' },
      { type: 'cmd',     text: 'git checkout -- deleted-page.html' },
      { type: 'err',     text: 'error: pathspec \'deleted-page.html\' did not match any files' },
    ],
    failMsg : '✖  PAGE NOT FOUND. RECOVERY FAILED.',
    emojis  : ['💥','😭','🤦','❌','😫','🚨'],
  },
  {
    label: 'Round 2',
    lines: [
      { type: 'divider', text: '─────────────────── attempt #2 ────────────────────' },
      { type: 'cmd',     text: 'python3 fix_404.py --aggressive' },
      { type: 'info',    text: 'Traceback (most recent call last):' },
      { type: 'err',     text: '  FileNotFoundError: [Errno 2] page does not exist' },
      { type: 'cmd',     text: 'docker run --rm magic-fixer:latest /fix-all' },
      { type: 'warn',    text: 'Unable to find image \'magic-fixer:latest\' locally' },
      { type: 'err',     text: 'docker: Error: No such image. Does it even exist?' },
      { type: 'cmd',     text: 'curl -X PATCH /missing-page -d "fix=true&please=yes"' },
      { type: 'info',    text: 'Connecting to server...' },
      { type: 'err',     text: '{"error": "lol no", "status": 404, "hint": "give up"}' },
      { type: 'cmd',     text: 'sudo reboot --force --really-force' },
      { type: 'warn',    text: 'Rebooting... [██████░░░░] 60%...' },
      { type: 'err',     text: 'KERNEL PANIC: still broken after reboot. Classic.' },
    ],
    failMsg : '✖  CRITICAL FAILURE. NOTHING WORKS.',
    emojis  : ['😤','🔥','💀','🤯','😡','⚠️'],
